# OLLAMA or OPENAI
LLM_CHOICE=OPENAI
OPENAI_API_KEY=REPLACE_WITH_YOUR_OPENAI_API_KEY
OLLAMA_URL=http://ollama-ki:11434
LLM_MODEL=gpt-3.5-turbo
# IF USING OLLAMA YOU NEED TO DECLARE A AN EMBEDING_LLM_MODEL
EMBEDDING_LLM_MODEL=snowflake-arctic-embed2:latest

GOOGLE_CREDENTIALS=./ai_agent_config/google-credentials.json
GOOGLE_SERVICE_ACCOUNT=./ai_agent_config/google-service-account.json
GOOGLE_MAIL_TOKEN=./ai_agent_config/google-mail-token.json
GOOGLE_CALENDAR_TOKEN=./ai_agent_config/google-calendar-token.json

#FOR THE GOOGLE PUBSUB
PROJECT_ID=noah-ai-agent
YOUR_TOPIC_NAME=gmail-notify-sub

#LOGGING
LOG_LEVEL=INFO